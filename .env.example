# Supabase project URL and anon (publishable) key — safe for the client.
# Find these under Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Supabase service-role key. Used by the ICS calendar route to
# read the requested user's meals. NEVER expose client-side. Find it under
# Project Settings → API → service_role (hidden by default).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only: random 32+ byte secret used to sign per-user calendar-feed
# URLs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Rotating this value invalidates all previously issued feed URLs.
CALENDAR_SIGNING_SECRET=replace-with-random-string
